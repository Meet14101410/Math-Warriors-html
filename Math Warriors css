body{
    font-family: Arial, sans-serif;
    text-align: center;
    background: #f4f4f4;
    padding: 50px;
}

h1{
    color: #2c3e50;
}

input, button{
    padding: 10px;
    margin: 5px;
}

button{
    background: #3498db;
    color: white;
    border: none;
    cursor: pointer;
}

button:hover{
    opacity: 0.8;
}

#result{
    font-weight: bold;
    margin-top: 10px;
}
